code = "shader_type spatial;
render_mode blend_mix, depth_draw_always, cull_back, diffuse_lambert, specular_disabled;

uniform sampler2D Texture2DParameter : source_color, filter_nearest, repeat_enable;
uniform vec4 albedoTint : source_color = vec4(1.000000, 0.000000, 0.000000, 1.000000);
uniform float scissor_alpha : hint_range(-0.5, 0.5) = 0;
uniform sampler2D tex_frg_2;
uniform sampler2D curve_frg_12 : repeat_disable;



void fragment() {
// Input:9
	vec2 n_out9p0 = UV;


// UVFunc:10
	vec2 n_in10p1 = vec2(2.00000, 2.00000);
	vec2 n_in10p2 = vec2(0.00000, 0.00000);
	vec2 n_out10p0 = (n_out9p0 - n_in10p2) * n_in10p1 + n_in10p2;


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Texture2DParameter, n_out10p0);


// ColorParameter:5
	vec4 n_out5p0 = albedoTint;


// ColorOp:7
	vec3 n_out7p0 = min(vec3(n_out8p0.xyz), vec3(n_out5p0.xyz));


// FloatParameter:4
	float n_out4p0 = scissor_alpha;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);


	vec3 n_out3p0;
// ColorFunc:3
	{
		vec3 c = vec3(n_out2p0.xyz);
		float max1 = max(c.r, c.g);
		float max2 = max(max1, c.b);
		n_out3p0 = vec3(max2, max2, max2);
	}


// VectorOp:13
	vec3 n_out13p0 = vec3(n_out4p0) + n_out3p0;


// CurveTexture:12
	float n_out12p0 = texture(curve_frg_12, vec2(n_out13p0.x)).r;


// Output:0
	ALBEDO = n_out7p0;
	ALPHA = n_out12p0;


}
