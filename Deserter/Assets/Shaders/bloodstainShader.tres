[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_always, cull_back, diffuse_lambert_wrap, specular_toon;

uniform float uvScale = 1;
uniform float speed : hint_range(0, 10) = 1;
uniform sampler2D tex_frg_14;
uniform float scissor_alpha : hint_range(-0.5, 0.5) = 0;
uniform sampler2D tex_frg_2;
uniform sampler2D curve_frg_12 : repeat_disable;
uniform float rough : hint_range(0, 1) = 1;



void fragment() {
// FloatParameter:21
	float n_out21p0 = uvScale;


// FloatParameter:17
	float n_out17p0 = speed;


// Input:16
	float n_out16p0 = TIME;


// FloatOp:18
	float n_out18p0 = n_out17p0 * n_out16p0;


// FloatOp:20
	float n_in20p1 = 0.01000;
	float n_out20p0 = n_out18p0 * n_in20p1;


// VectorCompose:19
	vec2 n_out19p0 = vec2(n_out20p0, n_out20p0);


// UVFunc:10
	vec2 n_out10p0 = (UV - n_out19p0) * vec2(n_out21p0) + n_out19p0;


// Texture2D:14
	vec4 n_out14p0 = texture(tex_frg_14, n_out10p0);


// FloatParameter:4
	float n_out4p0 = scissor_alpha;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);


	vec3 n_out3p0;
// ColorFunc:3
	{
		vec3 c = vec3(n_out2p0.xyz);
		float max1 = max(c.r, c.g);
		float max2 = max(max1, c.b);
		n_out3p0 = vec3(max2, max2, max2);
	}


// VectorOp:13
	vec3 n_out13p0 = vec3(n_out4p0) + n_out3p0;


// CurveTexture:12
	float n_out12p0 = texture(curve_frg_12, vec2(n_out13p0.x)).r;


// FloatParameter:15
	float n_out15p0 = rough;


// Output:0
	ALBEDO = vec3(n_out14p0.xyz);
	ALPHA = n_out12p0;
	SPECULAR = n_out15p0;


}
"
